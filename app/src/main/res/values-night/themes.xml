<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DailyTask" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/pastel_pink_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/pastel_pink</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/pastel_sky</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E1E1E1</item>
        <item name="colorSurfaceVariant">#2C2C2C</item>

        <!-- Fix for Dialogs (TimePicker, DatePicker) visibility -->
        <item name="materialAlertDialogTheme">@style/Theme.DailyTask.Dialog</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.DailyTask.Dialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E1E1E1</item>
    </style>
</resources>
