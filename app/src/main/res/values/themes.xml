<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DailyTask" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/pastel_pink_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/pastel_pink</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <item name="colorSecondary">@color/pastel_sky</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>

        <!-- Fix for Dialogs (TimePicker, DatePicker) visibility -->
        <item name="materialAlertDialogTheme">@style/Theme.DailyTask.Dialog</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <style name="Theme.DailyTask.Dialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Section header text -->
    <style name="TextAppearance.DailyTask.DateHeader" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
